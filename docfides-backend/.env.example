# App Configuration
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/docfides_dev"

# JWT
JWT_SECRET="your-secret-key-here-change-in-production"

# Email (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# Redis (Optional but recommended for production)
REDIS_HOST=localhost
REDIS_PORT=6379

# Rate Limiting Configuration
REQUEST_OTP_MAX_PER_HOUR=3
REQUEST_OTP_COOLDOWN_MINUTES=20
VERIFY_OTP_MAX_ATTEMPTS=5
VERIFY_OTP_LOCKOUT_MINUTES=30

# IPFS
# Local Kubo node default API: http://127.0.0.1:5001
IPFS_API_URL="http://127.0.0.1:5001"
IPFS_GATEWAY_URL="http://127.0.0.1:8080"
# Optional, for protected gateways/APIs. Example: "Bearer <token>" or "Basic <base64>"
IPFS_API_AUTH_HEADER=""
# When true, signing fails if IPFS upload fails. When false, signing continues and only logs a warning.
IPFS_UPLOAD_REQUIRED=false
# Optional Kubo replica nodes. Separate multiple replica APIs with commas.
# Example: IPFS_REPLICA_API_URLS="http://127.0.0.1:5002,http://127.0.0.1:5003"
IPFS_REPLICA_API_URLS="http://127.0.0.1:5002"
IPFS_REPLICA_API_AUTH_HEADER=""
# When true, signing fails if replica pinning fails. When false, upload to primary IPFS can still succeed.
IPFS_REPLICA_REQUIRED=false
IPFS_REPLICA_TIMEOUT_MS=60000

# Blockchain (Hyperledger Besu private Ethereum)
BLOCKCHAIN_RPC_URL="http://127.0.0.1:8545"
BLOCKCHAIN_PRIVATE_KEY="0xYOUR_PRIVATE_KEY_WITH_FUNDS"
DOCUMENT_REGISTRY_ADDRESS=""
# Optional override. By default backend reads src/module/blockchain/abi.json.
DOCUMENT_REGISTRY_ABI_PATH=""
# Use 0 for Besu private networks that allow zero-gas transactions. Leave empty for provider default fee data.
BLOCKCHAIN_GAS_PRICE=0
# When true, final signing fails if blockchain recording fails. When false, signing continues and only logs a warning.
BLOCKCHAIN_RECORD_REQUIRED=false

# Internal Certificate Authority
DOCCHAIN_CA_CERT_PATH="certs/docchain-ca.crt"
DOCCHAIN_CA_KEY_PATH="certs/docchain-ca.key"
DOCCHAIN_CA_KEY_PASSPHRASE=""
