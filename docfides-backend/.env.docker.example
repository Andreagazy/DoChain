# Runtime
NODE_ENV=production
PORT=4000
FRONTEND_URL=http://localhost:3000
DOCUMENT_VERIFICATION_URL=http://localhost:3000/verify

# Shared PostgreSQL on host/server. Replace password and host if needed.
DATABASE_URL=postgresql://docchain:change-this-password@host.docker.internal:5432/docchain_db?schema=public

# Auth
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=1d
CERT_SECRET_KEY=change-this-to-a-long-random-certificate-secret

# Email / OTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
REQUEST_OTP_MAX_PER_HOUR=3
REQUEST_OTP_COOLDOWN_MINUTES=20
VERIFY_OTP_MAX_ATTEMPTS=5
VERIFY_OTP_LOCKOUT_MINUTES=30

# Upload storage inside container. docker-compose mounts ./uploads to /app/uploads.
DOCUMENT_UPLOAD_DIR=uploads/documents
SIGNED_DOCUMENT_DIR=uploads/signed-documents
SIGNATURE_UPLOAD_DIR=uploads/signatures
KTP_UPLOAD_DIR=uploads/identity

# IPFS runs on host/WSL, container reaches it via host.docker.internal.
IPFS_API_URL=http://host.docker.internal:5001
IPFS_GATEWAY_URL=http://host.docker.internal:8080
IPFS_GATEWAY_URLS=http://host.docker.internal:8080,http://host.docker.internal:8081
IPFS_GATEWAY_TIMEOUT_MS=15000
IPFS_API_AUTH_HEADER=
IPFS_UPLOAD_REQUIRED=true
IPFS_REPLICA_API_URLS=http://host.docker.internal:5002
IPFS_REPLICA_API_AUTH_HEADER=
IPFS_REPLICA_REQUIRED=false
IPFS_REPLICA_TIMEOUT_MS=60000

# Blockchain. Fill when Besu/smart contract is ready.
BLOCKCHAIN_RPC_URL=http://host.docker.internal:8545
BLOCKCHAIN_PRIVATE_KEY=
DOCUMENT_REGISTRY_ADDRESS=
DOCUMENT_REGISTRY_ABI_PATH=
BLOCKCHAIN_GAS_PRICE=0
BLOCKCHAIN_RECORD_REQUIRED=false

# Internal Certificate Authority. docker-compose mounts ./certs to /app/certs.
DOCCHAIN_CA_CERT_PATH=certs/docchain-ca.crt
DOCCHAIN_CA_KEY_PATH=certs/docchain-ca.key
DOCCHAIN_CA_KEY_PASSPHRASE=
